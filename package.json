{
  "name": "nieves-portfolio",
  "version": "1.0.0",
  "description": "Portfolio website for Nieves Calvo - Architect, Interior Designer, Artist, Creative, and Explorer",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "bash -c 'set -a && source .env && set +a && wrangler deploy'",
    "deploy:env": "bash -c 'export $(grep -v \"^#\" .env | xargs) && wrangler deploy'",
    "preview": "wrangler dev --local",
    "setup": "echo 'Please edit .env file with your Cloudflare API Token'",
    "lint": "eslint src tests"
  },
  "keywords": [
    "portfolio",
    "architecture",
    "interior-design",
    "cloudflare-worker",
    "static-site"
  ],
  "author": "Nieves Calvo",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "wrangler": "^4.30.0"
  }
}
